# URL бэкенда API (подставляется при сборке образа).
# ВАЖНО: указывайте порт бэкенда, НЕ порт админки (80).
# http://IP/api без порта попадёт в nginx админки → 405 Not Allowed
# Пример:
# VITE_API_BASE_URL=http://203.0.113.10:5033/api
VITE_API_BASE_URL=http://localhost:5033/api

# Порт и интерфейс, на которых слушает админка
ADMIN_PORT=80
ADMIN_BIND_IP=0.0.0.0
